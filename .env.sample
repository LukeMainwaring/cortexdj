# Environment
ENVIRONMENT=development

# OpenAI (for Pydantic AI agent)
OPENAI_API_KEY=sk-...

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cortexdj
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Spotify (optional -- playlist features are hidden when not configured)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8003/api/spotify/callback

# Pydantic Logfire
LOGFIRE_TOKEN=your-logfire-token
