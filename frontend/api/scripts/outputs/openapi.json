  "paths": {
    "/api/agent/chat": {
      "post": {
        "tags": [
          "agent"
        ],
        "summary": "Stream Chat",
        "description": "Brain assistant streaming endpoint.\n\nUses VercelAIAdapter to handle parsing, agent execution, and streaming\nin Vercel AI SDK protocol format.",
        "operationId": "streamChat",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/audio/preview/{cache_key}": {
      "get": {
        "tags": [
          "audio"
        ],
        "summary": "Get Audio Preview",
        "description": "Serve a cached iTunes m4a preview by its content-addressed cache key.\n\nSame-origin delivery exists so the frontend waveform component can\n`fetch` + `decodeAudioData` the bytes — Apple's preview CDN does not\nreliably set CORS headers for cross-origin Web Audio decoding.",
        "operationId": "getAudioPreview",
        "parameters": [
          {
            "name": "cache_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Cache Key"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/health/db": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Db Health Check",
        "description": "Check the database connection.",
        "operationId": "dbHealthCheck",
